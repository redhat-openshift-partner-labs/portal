# Database Configuration
#
# IMPORTANT: The Prisma client must be generated for the matching database.
# Run `pnpm prisma generate` for SQLite or `pnpm db:pg:generate` for PostgreSQL.
#
# For local development (SQLite):
DATABASE_URL="file:./prisma/dev.db"

# For production (PostgreSQL):
# DATABASE_URL="postgresql://user:password@db-service.namespace.svc.cluster.local:5432/opdb?schema=public"

# OIDC Provider
OAUTH_CLIENT_ID=your-oidc-client-id
OAUTH_CLIENT_SECRET=your-oidc-client-secret
OAUTH_AUTH_URL=https://your-provider.com/auth
OAUTH_TOKEN_URL=https://your-provider.com/token

# Auth
AUTH_SECRET=your-auth-secret

# App URL
APP_URL=http://localhost:3000
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Mapbox (optional)
NUXT_PUBLIC_MAPBOX_TOKEN=

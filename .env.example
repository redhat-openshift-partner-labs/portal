# Database Configuration
#
# IMPORTANT: The Prisma client must be generated for the matching database.
# Run `pnpm prisma generate` for SQLite or `pnpm db:pg:generate` for PostgreSQL.
#
# For local development (SQLite):
DATABASE_URL="file:./prisma/dev.db"

# For production (PostgreSQL):
# DATABASE_URL="postgresql://user:password@db-service.namespace.svc.cluster.local:5432/opdb?schema=public"

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Auth
AUTH_SECRET=your-auth-secret

# App URL
APP_URL=http://localhost:3000
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Mapbox (optional)
NUXT_PUBLIC_MAPBOX_TOKEN=

{
  "name": "portal",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:pg:generate": "prisma generate --config=prisma.config.postgresql.ts",
    "db:pg:push": "prisma db push --config=prisma.config.postgresql.ts",
    "db:pg:push:sql": "tsx scripts/pg-push-manual.ts",
    "db:pg:migrate": "prisma migrate dev --config=prisma.config.postgresql.ts",
    "db:pg:deploy": "prisma migrate deploy --config=prisma.config.postgresql.ts",
    "db:pg:studio": "prisma studio --config=prisma.config.postgresql.ts",
    "db:validate": "tsx scripts/validate-schemas.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.1",

    "db:pg:deploy": "prisma migrate deploy --config=prisma.config.postgresql.ts",
    "db:pg:studio": "prisma studio --config=prisma.config.postgresql.ts",
    "db:validate": "tsx scripts/validate-schemas.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.1",

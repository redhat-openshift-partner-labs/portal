// Prisma Schema for OpenShift Partner Labs Dashboard
// Uses SQLite for local development, PostgreSQL for production

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Lab {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  status      String    @default("pending") // pending, active, completed, archived
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  completedAt DateTime? @map("completed_at")

  sessions Session[]

  @@map("labs")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  picture   String?
  group     String?  // oplmgr, opldev, or null for regular users
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions Session[]
  notes    Note[]

  @@map("users")
}

model Session {
  id          Int       @id @default(autoincrement())
  labId       Int       @map("lab_id")
  userId      Int       @map("user_id")
  completed   Boolean   @default(false)
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  lab  Lab  @relation(fields: [labId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model Cost {
  id        Int      @id @default(autoincrement())
  amount    Float    @map("cost")
  date      DateTime
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("costs")
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  requests Request[]

  @@map("companies")
}

model Request {
  id        Int      @id @default(autoincrement())
  cluster   String
  companyId Int      @map("company_id")
  timezone  String
  status    String   @default("Pending") // Pending, Active, Approved, Running, Hibernating
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  notes   Note[]

  @@map("requests")
}

model Note {
  id        Int      @id @default(autoincrement())
  requestId Int      @map("request_id")
  content   String
  authorId  Int?     @map("author_id")
  immutable Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  request Request @relation(fields: [requestId], references: [id])
  author  User?   @relation(fields: [authorId], references: [id])

  @@map("notes")
}
